# Server Configuration
PORT=3000
NODE_ENV=development

# Enable AI verification (set to "true" to use AI, otherwise uses smart mocks)
ENABLE_AI=true

# AI API Keys - Choose ONE of the following:

# Option 1: Groq (RECOMMENDED - FREE)
# Get your free key from: https://console.groq.com/keys
# Uses Llama 3.3 70B - fast and capable
GROQ_API_KEY=gsk_...

# Option 2: OpenAI (GPT-4o-mini)
# Get your key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Option 3: Anthropic (Claude)
# Get your key from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# Note: If ENABLE_AI=false or no API key is set, the system will use 
# intelligent mock responses. The extension will still work.
